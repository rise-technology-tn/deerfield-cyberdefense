{
  "name": "deerfield-cyberdefense",
  "version": "1.0.0",
  "private": true,
  "description": "Deerfield Cyberdefense — Managed Security Services marketing site. Next.js (App Router), hardened against common web attacks.",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "postinstall": "[ -z \"$GANDI\" ] || npm run build",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --omit=dev",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "config": {
    "NODE_ENV": "development"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "lucide-react": "0.460.0",
    "next": "15.5.18",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.17.0",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "eslint": "9.17.0",
    "eslint-config-next": "15.5.18",
    "typescript": "5.6.3",
    "wrangler": "^4.96.0"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "postcss": "^8.5.10"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
